<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>ProfessorDashboard</class>
 <widget class="QWidget" name="ProfessorDashboard">
  <layout class="QVBoxLayout" name="mainLayout">
   <item><widget class="QLabel" name="welcomeLabel"><property name="text"><string>Dashboard Profesor</string></property><property name="alignment"><set>Qt::AlignmentFlag::AlignCenter</set></property></widget></item>
   <item><layout class="QHBoxLayout" name="detailsLayout">
    <item><widget class="QLabel" name="userLabel"><property name="text"><string>Utilizator:</string></property></widget></item>
    <item><widget class="QLabel" name="roleLabel"><property name="text"><string>Rol:</string></property></widget></item>
    <item><widget class="QLabel" name="connectionLabel"><property name="text"><string>Neconectat</string></property></widget></item>
   </layout></item>
   <item><layout class="QHBoxLayout" name="contentLayout">
    <item><layout class="QVBoxLayout" name="navigationLayout">
     <item><widget class="QPushButton" name="homeButton"><property name="text"><string>Acasă</string></property></widget></item>
     <item><widget class="QPushButton" name="myCoursesButton"><property name="text"><string>Cursurile mele</string></property></widget></item>
     <item><widget class="QPushButton" name="createCourseButton"><property name="text"><string>Creează curs</string></property></widget></item>
     <item><widget class="QPushButton" name="lessonsButton"><property name="text"><string>Lecții</string></property></widget></item>
     <item><widget class="QPushButton" name="evaluationsButton"><property name="text"><string>Evaluări</string></property></widget></item>
     <item><widget class="QPushButton" name="studentsButton"><property name="text"><string>Studenți</string></property></widget></item>
     <item><spacer name="navSpacer"><property name="orientation"><enum>Qt::Orientation::Vertical</enum></property><property name="sizeHint" stdset="0"><size><width>20</width><height>40</height></size></property></spacer></item>
    </layout></item>
    <item><widget class="QStackedWidget" name="pagesStack">
     <widget class="QWidget" name="homePage"><layout class="QVBoxLayout" name="homeLayout"><item><widget class="QLabel" name="homeLabel"><property name="text"><string>Funcționalitățile Profesorului vor fi implementate în pașii următori.</string></property><property name="alignment"><set>Qt::AlignmentFlag::AlignCenter</set></property><property name="wordWrap"><bool>true</bool></property></widget></item></layout></widget>
     <widget class="QWidget" name="myCoursesPage"><layout class="QVBoxLayout" name="myCoursesLayout"><item><widget class="QLabel" name="myCoursesLabel"><property name="text"><string>Gestionarea cursurilor va fi implementată într-un pas ulterior.</string></property><property name="alignment"><set>Qt::AlignmentFlag::AlignCenter</set></property></widget></item></layout></widget>
     <widget class="QWidget" name="createCoursePage"><layout class="QVBoxLayout" name="createCourseLayout"><item><widget class="QLabel" name="createCourseLabel"><property name="text"><string>Crearea cursurilor va fi implementată într-un pas ulterior.</string></property><property name="alignment"><set>Qt::AlignmentFlag::AlignCenter</set></property></widget></item></layout></widget>
     <widget class="QWidget" name="lessonsPage"><layout class="QVBoxLayout" name="lessonsLayout"><item><widget class="QLabel" name="lessonsLabel"><property name="text"><string>Gestionarea lecțiilor va fi implementată într-un pas ulterior.</string></property><property name="alignment"><set>Qt::AlignmentFlag::AlignCenter</set></property></widget></item></layout></widget>
     <widget class="QWidget" name="evaluationsPage"><layout class="QVBoxLayout" name="evaluationsLayout"><item><widget class="QLabel" name="evaluationsLabel"><property name="text"><string>Gestionarea evaluărilor va fi implementată într-un pas ulterior.</string></property><property name="alignment"><set>Qt::AlignmentFlag::AlignCenter</set></property></widget></item></layout></widget>
     <widget class="QWidget" name="studentsPage"><layout class="QVBoxLayout" name="studentsLayout"><item><widget class="QLabel" name="studentsLabel"><property name="text"><string>Lista studenților va fi implementată într-un pas ulterior.</string></property><property name="alignment"><set>Qt::AlignmentFlag::AlignCenter</set></property></widget></item></layout></widget>
    </widget></item>
   </layout></item>
  </layout>
 </widget>
