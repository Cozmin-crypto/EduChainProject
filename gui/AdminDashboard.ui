<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>AdminDashboard</class>
 <widget class="QWidget" name="AdminDashboard">
  <layout class="QVBoxLayout" name="mainLayout">
   <item><widget class="QLabel" name="welcomeLabel"><property name="text"><string>Dashboard Administrator</string></property><property name="alignment"><set>Qt::AlignmentFlag::AlignCenter</set></property></widget></item>
   <item><layout class="QHBoxLayout" name="detailsLayout">
    <item><widget class="QLabel" name="userLabel"><property name="text"><string>Utilizator:</string></property></widget></item>
    <item><widget class="QLabel" name="roleLabel"><property name="text"><string>Rol:</string></property></widget></item>
    <item><widget class="QLabel" name="connectionLabel"><property name="text"><string>Neconectat</string></property></widget></item>
   </layout></item>
   <item><layout class="QHBoxLayout" name="contentLayout">
    <item><layout class="QVBoxLayout" name="navigationLayout">
     <item><widget class="QPushButton" name="homeButton"><property name="text"><string>Acasă</string></property></widget></item>
     <item><widget class="QPushButton" name="usersButton"><property name="text"><string>Utilizatori</string></property></widget></item>
     <item><widget class="QPushButton" name="coursesButton"><property name="text"><string>Cursuri</string></property></widget></item>
     <item><widget class="QPushButton" name="statisticsButton"><property name="text"><string>Statistici</string></property></widget></item>
     <item><widget class="QPushButton" name="administrationButton"><property name="text"><string>Administrare</string></property></widget></item>
     <item><spacer name="navSpacer"><property name="orientation"><enum>Qt::Orientation::Vertical</enum></property><property name="sizeHint" stdset="0"><size><width>20</width><height>40</height></size></property></spacer></item>
    </layout></item>
    <item><widget class="QStackedWidget" name="pagesStack">
     <widget class="QWidget" name="homePage"><layout class="QVBoxLayout" name="homeLayout"><item><widget class="QLabel" name="homeLabel"><property name="text"><string>Funcționalitățile Administratorului vor fi implementate într-un pas ulterior.</string></property><property name="alignment"><set>Qt::AlignmentFlag::AlignCenter</set></property><property name="wordWrap"><bool>true</bool></property></widget></item></layout></widget>
     <widget class="QWidget" name="usersPage"><layout class="QVBoxLayout" name="usersLayout"><item><widget class="QLabel" name="usersLabel"><property name="text"><string>Administrarea utilizatorilor va fi implementată într-un pas ulterior.</string></property><property name="alignment"><set>Qt::AlignmentFlag::AlignCenter</set></property></widget></item></layout></widget>
     <widget class="QWidget" name="coursesPage"><layout class="QVBoxLayout" name="coursesLayout"><item><widget class="QLabel" name="coursesLabel"><property name="text"><string>Administrarea cursurilor va fi implementată într-un pas ulterior.</string></property><property name="alignment"><set>Qt::AlignmentFlag::AlignCenter</set></property></widget></item></layout></widget>
     <widget class="QWidget" name="statisticsPage"><layout class="QVBoxLayout" name="statisticsLayout"><item><widget class="QLabel" name="statisticsLabel"><property name="text"><string>Statisticile vor fi implementate într-un pas ulterior.</string></property><property name="alignment"><set>Qt::AlignmentFlag::AlignCenter</set></property></widget></item></layout></widget>
     <widget class="QWidget" name="administrationPage"><layout class="QVBoxLayout" name="administrationLayout"><item><widget class="QLabel" name="administrationLabel"><property name="text"><string>Operațiile administrative vor fi implementate într-un pas ulterior.</string></property><property name="alignment"><set>Qt::AlignmentFlag::AlignCenter</set></property></widget></item></layout></widget>
    </widget></item>
   </layout></item>
  </layout>
 </widget>
